                            : 'border-border bg-secondary/30 hover:border-primary/50'
                        }`}
                      >
                        {goal.label}
                      </button>
                    ))}
                  </div>
                )}

                {/* Step 4: Meals per day + fasting */}
                {step === 4 && (
                  <div className="space-y-4">
