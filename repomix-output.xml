        </div>
      </div>

      {/* Intensity */}
      <div>
        <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-2">
          Intensity
        </p>
        <div className="grid grid-cols-3 gap-2">
          {INTENSITIES.map(level => (
            <button
