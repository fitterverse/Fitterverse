// ──────────────────────────────────────────────────────────────────
// Shared plan types — used by product app (read) and CRM (read/write)
// ──────────────────────────────────────────────────────────────────

export type PlanStatus = 'draft' | 'published' | 'archived'
export type DayOfWeek = 0 | 1 | 2 | 3 | 4 | 5 | 6  // 0 = Monday
export type MealSlot =
  | 'breakfast'
  | 'morning_snack'
  | 'lunch'
